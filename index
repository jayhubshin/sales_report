<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EPC 주간/월간/분기 대시보드</title>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }
        .header { background: linear-gradient(135deg, #1e293b, #334155); padding: 20px 30px; border-bottom: 2px solid #3b82f6; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { font-size: 22px; color: #60a5fa; }
        .header .date-info { color: #94a3b8; font-size: 13px; }
        .upload-section { background: #1e293b; padding: 20px 30px; border-bottom: 1px solid #334155; display: flex; gap: 20px; flex-wrap: wrap; align-items: center; }
        .upload-box { background: #0f172a; border: 2px dashed #475569; border-radius: 10px; padding: 15px 20px; cursor: pointer; transition: all .3s; flex: 1; min-width: 220px; text-align: center; }
        .upload-box:hover { border-color: #3b82f6; background: #1a2332; }
        .upload-box.loaded { border-color: #22c55e; border-style: solid; }
        .upload-box label { display: block; cursor: pointer; font-size: 13px; color: #94a3b8; }
        .upload-box .status { font-size: 11px; margin-top: 5px; color: #22c55e; }
        .upload-box input { display: none; }
        .tab-bar { background: #1e293b; padding: 0 30px; display: flex; gap: 0; border-bottom: 1px solid #334155; }
        .tab { padding: 12px 24px; cursor: pointer; color: #94a3b8; font-size: 14px; border-bottom: 3px solid transparent; transition: all .2s; }
        .tab:hover { color: #e2e8f0; }
        .tab.active { color: #3b82f6; border-bottom-color: #3b82f6; background: rgba(59,130,246,.08); }
        .period-bar { background: #1e293b; padding: 10px 30px; display: flex; gap: 10px; align-items: center; border-bottom: 1px solid #334155; }
        .period-btn { padding: 6px 16px; border-radius: 6px; border: 1px solid #475569; background: transparent; color: #94a3b8; cursor: pointer; font-size: 12px; }
        .period-btn.active { background: #3b82f6; border-color: #3b82f6; color: #fff; }
        .period-bar select, .period-bar input { background: #0f172a; border: 1px solid #475569; color: #e2e8f0; padding: 6px 12px; border-radius: 6px; font-size: 12px; }
        .content { padding: 20px 30px; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .grid { display: grid; gap: 16px; margin-bottom: 20px; }
        .grid-4 { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
        .grid-2 { grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); }
        .grid-3 { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
        .card { background: #1e293b; border-radius: 12px; padding: 20px; border: 1px solid #334155; }
        .card h3 { font-size: 13px; color: #94a3b8; margin-bottom: 8px; font-weight: 500; }
        .card .value { font-size: 28px; font-weight: 700; color: #f8fafc; }
        .card .sub { font-size: 12px; color: #64748b; margin-top: 4px; }
        .card .change { font-size: 12px; margin-top: 4px; }
        .card .change.up { color: #22c55e; }
        .card .change.down { color: #ef4444; }
        .chart-card { background: #1e293b; border-radius: 12px; padding: 20px; border: 1px solid #334155; }
        .chart-card h3 { font-size: 14px; color: #e2e8f0; margin-bottom: 15px; }
        .chart-container { position: relative; height: 280px; }
        table { width: 100%; border-collapse: collapse; font-size: 12px; }
        th { background: #0f172a; padding: 10px 12px; text-align: left; color: #94a3b8; font-weight: 600; position: sticky; top: 0; }
        td { padding: 8px 12px; border-bottom: 1px solid #1e293b; color: #cbd5e1; }
        tr:hover td { background: rgba(59,130,246,.05); }
        .table-wrap { max-height: 400px; overflow-y: auto; border-radius: 8px; border: 1px solid #334155; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
        .badge-blue { background: rgba(59,130,246,.15); color: #60a5fa; }
        .badge-green { background: rgba(34,197,94,.15); color: #22c55e; }
        .badge-yellow { background: rgba(234,179,8,.15); color: #eab308; }
        .badge-red { background: rgba(239,68,68,.15); color: #ef4444; }
        .no-data { text-align: center; padding: 60px 20px; color: #64748b; }
        .no-data .icon { font-size: 48px; margin-bottom: 16px; }
        .no-data p { font-size: 14px; }
        .summary-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
        .summary-chip { background: #0f172a; border: 1px solid #334155; border-radius: 8px; padding: 8px 14px; font-size: 12px; }
        .summary-chip strong { color: #60a5fa; }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #0f172a; }
        ::-webkit-scrollbar-thumb { background: #475569; border-radius: 3px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>📊 EPC 현장관리 대시보드</h1>
        <div class="date-info">보고일: <span id="reportDate"></span></div>
    </div>

    <div class="upload-section">
        <div class="upload-box" id="box1">
            <label for="file1">📁 현장목록 (.xlsx)<input type="file" id="file1" accept=".xlsx,.xls" onchange="loadFile(this,'현장목록')"></label>
            <div class="status" id="status1"></div>
        </div>
        <div class="upload-box" id="box2">
            <label for="file2">📁 실사목록 (.xlsx)<input type="file" id="file2" accept=".xlsx,.xls" onchange="loadFile(this,'실사목록')"></label>
            <div class="status" id="status2"></div>
        </div>
        <div class="upload-box" id="box3">
            <label for="file3">📁 서류목록 (.xlsx)<input type="file" id="file3" accept=".xlsx,.xls" onchange="loadFile(this,'서류목록')"></label>
            <div class="status" id="status3"></div>
        </div>
    </div>

    <div class="tab-bar">
        <div class="tab active" onclick="switchTab('overview')">📋 종합현황</div>
        <div class="tab" onclick="switchTab('site')">🏗️ 현장목록</div>
        <div class="tab" onclick="switchTab('inspect')">🔍 실사목록</div>
        <div class="tab" onclick="switchTab('doc')">📄 서류목록</div>
    </div>

    <div class="period-bar">
        <span style="font-size:12px;color:#94a3b8;">기간:</span>
        <button class="period-btn" onclick="setPeriod('week')">주간</button>
        <button class="period-btn active" onclick="setPeriod('month')">월간</button>
        <button class="period-btn" onclick="setPeriod('quarter')">분기</button>
        <span style="font-size:12px;color:#94a3b8;margin-left:16px;">기준월:</span>
        <input type="month" id="baseMonth" onchange="refresh()">
    </div>

    <div class="content">
        <!-- 종합 현황 -->
        <div class="tab-content active" id="tc-overview">
            <div class="grid grid-4" id="overviewCards"></div>
            <div class="grid grid-2" id="overviewCharts"></div>
        </div>

        <!-- 현장목록 -->
        <div class="tab-content" id="tc-site">
            <div class="grid grid-4" id="siteCards"></div>
            <div class="grid grid-2" id="siteCharts"></div>
            <div class="chart-card" style="margin-top:16px">
                <h3>📋 현장 상세 목록 (기간 내 등록)</h3>
                <div class="table-wrap" id="siteTable"></div>
            </div>
        </div>

        <!-- 실사목록 -->
        <div class="tab-content" id="tc-inspect">
            <div class="grid grid-4" id="inspectCards"></div>
            <div class="grid grid-2" id="inspectCharts"></div>
            <div class="chart-card" style="margin-top:16px">
                <h3>📋 실사 상세 목록 (기간 내 진행)</h3>
                <div class="table-wrap" id="inspectTable"></div>
            </div>
        </div>

        <!-- 서류목록 -->
        <div class="tab-content" id="tc-doc">
            <div class="grid grid-4" id="docCards"></div>
            <div class="grid grid-2" id="docCharts"></div>
            <div class="chart-card" style="margin-top:16px">
                <h3>📋 계약 상세 목록 (기간 내 접수)</h3>
                <div class="table-wrap" id="docTable"></div>
            </div>
        </div>
    </div>

<script>
const DATA = {};
let currentPeriod = 'month';
let charts = {};

document.getElementById('reportDate').textContent = new Date().toLocaleDateString('ko-KR');
document.getElementById('baseMonth').value = new Date().toISOString().slice(0,7);

function loadFile(input, key) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const wb = XLSX.read(e.target.result, {type:'array', cellDates:true});
            const ws = wb.Sheets[wb.SheetNames[0]];
            const json = XLSX.utils.sheet_to_json(ws, {defval:''});
            DATA[key] = json;
            const idx = key === '현장목록' ? 1 : key === '실사목록' ? 2 : 3;
            document.getElementById('box'+idx).classList.add('loaded');
            document.getElementById('status'+idx).textContent = `✅ ${json.length}건 로드됨`;
            refresh();
        } catch(err) {
            alert('파일 파싱 오류: ' + err.message);
        }
    };
    reader.readAsArrayBuffer(file);
}

function setPeriod(p) {
    currentPeriod = p;
    document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
    event.target.classList.add('active');
    refresh();
}

function switchTab(id) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
    document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
    document.getElementById('tc-'+id).classList.add('active');
}

function getDateRange() {
    const base = document.getElementById('baseMonth').value;
    if (!base) return {start: new Date('2020-01-01'), end: new Date('2030-12-31'), prevStart: new Date('2020-01-01'), prevEnd: new Date('2020-01-01')};
    const [y, m] = base.split('-').map(Number);
    let start, end, prevStart, prevEnd;
    if (currentPeriod === 'week') {
        end = new Date(y, m, 0);
        start = new Date(end); start.setDate(end.getDate() - 6);
        prevEnd = new Date(start); prevEnd.setDate(start.getDate() - 1);
        prevStart = new Date(prevEnd); prevStart.setDate(prevEnd.getDate() - 6);
    } else if (currentPeriod === 'month') {
        start = new Date(y, m-1, 1);
        end = new Date(y, m, 0);
        prevStart = new Date(y, m-2, 1);
        prevEnd = new Date(y, m-1, 0);
    } else {
        const q = Math.ceil(m / 3);
        start = new Date(y, (q-1)*3, 1);
        end = new Date(y, q*3, 0);
        prevStart = new Date(y, (q-2)*3, 1);
        prevEnd = new Date(y, (q-1)*3, 0);
    }
    return {start, end, prevStart, prevEnd};
}

function parseDate(v) {
    if (!v) return null;
    if (v instanceof Date) return v;
    const s = String(v).trim();
    if (s === '-' || s === '' || s === 'nan') return null;
    const d = new Date(s);
    return isNaN(d.getTime()) ? null : d;
}

function inRange(d, s, e) {
    if (!d) return false;
    return d >= s && d <= e;
}

function countBy(arr, key) {
    const m = {};
    arr.forEach(r => { const v = r[key] || '미분류'; m[v] = (m[v]||0) + 1; });
    return m;
}

function topN(obj, n=8) {
    const sorted = Object.entries(obj).sort((a,b) => b[1]-a[1]);
    const top = sorted.slice(0, n);
    const rest = sorted.slice(n).reduce((s,e) => s+e[1], 0);
    if (rest > 0) top.push(['기타', rest]);
    return {labels: top.map(e=>e[0]), values: top.map(e=>e[1])};
}

function makeChart(containerId, id, type, labels, datasets, opts={}) {
    if (charts[id]) charts[id].destroy();
    const container = document.getElementById(containerId);
    let canvas = document.getElementById(id);
    if (!canvas) {
        const card = document.createElement('div');
        card.className = 'chart-card';
        card.innerHTML = `<h3>${opts.title||''}</h3><div class="chart-container"><canvas id="${id}"></canvas></div>`;
        container.appendChild(card);
        canvas = document.getElementById(id);
    }
    const colors = ['#3b82f6','#22c55e','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#ec4899','#f97316','#14b8a6','#a855f7','#6366f1','#84cc16'];
    charts[id] = new Chart(canvas, {
        type,
        data: {
            labels,
            datasets: datasets.map((ds, i) => ({
                ...ds,
                backgroundColor: ds.backgroundColor || (type==='doughnut'||type==='pie' ? colors : colors[i] + '99'),
                borderColor: ds.borderColor || colors[i],
                borderWidth: type==='doughnut'||type==='pie' ? 2 : 1,
            }))
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { labels: { color: '#94a3b8', font: {size:11} }, position: type==='doughnut'?'right':'top' },
            },
            scales: type==='doughnut'||type==='pie' ? {} : {
                x: { ticks: { color: '#64748b', font:{size:10}, maxRotation:45 }, grid: { color: '#1e293b' } },
                y: { ticks: { color: '#64748b', font:{size:10} }, grid: { color: '#1e293b33' }, beginAtZero: true }
            }
        }
    });
}

function renderCards(containerId, cards) {
    const el = document.getElementById(containerId);
    el.innerHTML = cards.map(c => `
        <div class="card">
            <h3>${c.label}</h3>
            <div class="value">${c.value}</div>
            ${c.sub ? `<div class="sub">${c.sub}</div>` : ''}
            ${c.change !== undefined ? `<div class="change ${c.change>=0?'up':'down'}">${c.change>=0?'▲':'▼'} ${Math.abs(c.change)}건 (전기대비)</div>` : ''}
        </div>
    `).join('');
}

function renderTable(containerId, headers, rows) {
    const el = document.getElementById(containerId);
    if (!rows.length) { el.innerHTML = '<div class="no-data"><p>해당 기간 데이터 없음</p></div>'; return; }
    const display = rows.slice(0, 200);
    el.innerHTML = `<table><thead><tr>${headers.map(h=>`<th>${h}</th>`).join('')}</tr></thead><tbody>${display.map(r=>`<tr>${r.map(c=>`<td>${c}</td>`).join('')}</tr>`).join('')}</tbody></table>` + (rows.length > 200 ? `<div style="padding:10px;text-align:center;color:#64748b;font-size:12px;">... 외 ${rows.length-200}건 더 있음</div>` : '');
}

function findCol(row, ...keywords) {
    for (const key of Object.keys(row)) {
        const k = String(key).replace(/\s/g,'');
        for (const kw of keywords) {
            if (k.includes(kw)) return key;
        }
    }
    return null;
}

function refresh() {
    const range = getDateRange();
    refreshOverview(range);
    refreshSite(range);
    refreshInspect(range);
    refreshDoc(range);
}

function refreshOverview(range) {
    const cards = [];
    const siteData = DATA['현장목록'] || [];
    const inspData = DATA['실사목록'] || [];
    const docData = DATA['서류목록'] || [];

    // Site counts
    if (siteData.length) {
        const colDate = findCol(siteData[0], '등록일');
        const cur = siteData.filter(r => inRange(parseDate(r[colDate]), range.start, range.end));
        const prev = siteData.filter(r => inRange(parseDate(r[colDate]), range.prevStart, range.prevEnd));
        cards.push({label:'신규 현장등록', value: cur.length+'건', change: cur.length - prev.length});
        const colParking = findCol(siteData[0], '주차면');
        const totalParking = cur.reduce((s,r) => s + (parseInt(String(r[colParking]).replace(/,/g,''))||0), 0);
        cards.push({label:'총 주차면 수', value: totalParking.toLocaleString()+'면', sub:'기간 내 등록현장'});
    }
    if (inspData.length) {
        const colDate = findCol(inspData[0], '실사진행일');
        const cur = inspData.filter(r => { const d = parseDate(r[colDate]); return d && inRange(d, range.start, range.end); });
        const prev = inspData.filter(r => { const d = parseDate(r[colDate]); return d && inRange(d, range.prevStart, range.prevEnd); });
        cards.push({label:'실사 진행', value: cur.length+'건', change: cur.length - prev.length});
        const colSpot = findCol(inspData[0], '거점수');
        const totalSpot = cur.reduce((s,r) => s + (parseInt(r[colSpot])||0), 0);
        cards.push({label:'총 거점 수', value: totalSpot.toLocaleString()+'개', sub:'실사 완료건'});
    }
    if (docData.length) {
        const colDate = findCol(docData[0], '업체접수일자', '접수일자');
        const colStatus = findCol(docData[0], '계약여부');
        const colQty = findCol(docData[0], '계약수량', '수량');
        const cur = docData.filter(r => inRange(parseDate(r[colDate]), range.start, range.end));
        const prev = docData.filter(r => inRange(parseDate(r[colDate]), range.prevStart, range.prevEnd));
        const contracted = cur.filter(r => String(r[colStatus]).includes('체결'));
        cards.push({label:'서류 접수', value: cur.length+'건', change: cur.length - prev.length});
        cards.push({label:'계약 체결', value: contracted.length+'건', sub: `체결률 ${cur.length?Math.round(contracted.length/cur.length*100):0}%`});
        const totalQty = contracted.reduce((s,r) => s + (parseInt(r[colQty])||0), 0);
        cards.push({label:'계약 충전기 수량', value: totalQty.toLocaleString()+'기', sub:'체결건 합산'});
    }
    if (!cards.length) cards.push({label:'데이터 없음', value:'-', sub:'파일을 업로드하세요'});
    renderCards('overviewCards', cards);

    // Charts
    document.getElementById('overviewCharts').innerHTML = '';
    if (siteData.length) {
        const colDate = findCol(siteData[0], '등록일');
        const colCompany = findCol(siteData[0], '업체명');
        const cur = siteData.filter(r => inRange(parseDate(r[colDate]), range.start, range.end));
        const byCompany = topN(countBy(cur, colCompany), 10);
        makeChart('overviewCharts','ov-company','bar', byCompany.labels, [{label:'현장등록 수', data:byCompany.values}], {title:'업체별 현장등록 현황'});
    }
    if (docData.length) {
        const colDate = findCol(docData[0], '업체접수일자', '접수일자');
        const colBiz = findCol(docData[0], '사업구분-2');
        const cur = docData.filter(r => inRange(parseDate(r[colDate]), range.start, range.end));
        const byBiz = topN(countBy(cur, colBiz), 8);
        makeChart('overviewCharts','ov-biz','doughnut', byBiz.labels, [{data:byBiz.values}], {title:'사업구분별 계약 현황'});
    }
}

function refreshSite(range) {
    const data = DATA['현장목록'] || [];
    if (!data.length) { renderCards('siteCards',[{label:'데이터 없음',value:'-',sub:'현장목록 파일 업로드 필요'}]); document.getElementById('siteCharts').innerHTML=''; document.getElementById('siteTable').innerHTML=''; return; }
    const colDate = findCol(data[0], '등록일');
    const colCompany = findCol(data[0], '업체명');
    const colPath = findCol(data[0], '인입경로');
    const colType = findCol(data[0], '시설유형');
    const colParking = findCol(data[0], '주차면');
    const colName = findCol(data[0], '현장명');
    const colAddr = findCol(data[0], '주소');

    const cur = data.filter(r => inRange(parseDate(r[colDate]), range.start, range.end));
    const prev = data.filter(r => inRange(parseDate(r[colDate]), range.prevStart, range.prevEnd));

    const byCompany = countBy(cur, colCompany);
    const byPath = countBy(cur, colPath);
    const byType = countBy(cur, colType);

    renderCards('siteCards', [
        {label:'기간 내 등록', value:cur.length+'건', change: cur.length - prev.length},
        {label:'전기대비', value:prev.length+'건', sub:'이전 기간'},
        {label:'소개 경로', value:(byPath['소개']||0)+'건', sub:`전체 ${cur.length}건 중`},
        {label:'공동주택시설', value:(byType['공동주택시설']||0)+'건'}
    ]);

    document.getElementById('siteCharts').innerHTML = '';
    const tc = topN(byCompany, 10);
    makeChart('siteCharts','s-company','bar', tc.labels, [{label:'등록 수', data:tc.values}], {title:'업체별 현장등록 현황'});
    const tp = topN(byPath, 6);
    makeChart('siteCharts','s-path','doughnut', tp.labels, [{data:tp.values}], {title:'인입경로별 분포'});

    // 월별 추이
    const months = {};
    data.forEach(r => { const d = parseDate(r[colDate]); if(d){ const k = d.toISOString().slice(0,7); months[k]=(months[k]||0)+1; }});
    const mk = Object.keys(months).sort().slice(-6);
    makeChart('siteCharts','s-trend','line', mk, [{label:'월별 등록', data:mk.map(k=>months[k]), fill:true, tension:.3}], {title:'최근 6개월 등록 추이'});

    const tt = topN(byType, 8);
    makeChart('siteCharts','s-type','bar', tt.labels, [{label:'시설수', data:tt.values}], {title:'시설유형별 분포'});

    renderTable('siteTable', ['현장명','업체명','주소','인입경로','시설유형','주차면','등록일'],
        cur.map(r => [r[colName],r[colCompany],r[colAddr],r[colPath],r[colType],r[colParking],String(r[colDate]).slice(0,10)])
    );
}

function refreshInspect(range) {
    const data = DATA['실사목록'] || [];
    if (!data.length) { renderCards('inspectCards',[{label:'데이터 없음',value:'-',sub:'실사목록 파일 업로드 필요'}]); document.getElementById('inspectCharts').innerHTML=''; document.getElementById('inspectTable').innerHTML=''; return; }
    const colPDate = findCol(data[0], '실사진행일');
    const colRDate = findCol(data[0], '실사요청일');
    const colCompany = findCol(data[0], '영업업체명', '영업');
    const colSpot = findCol(data[0], '거점수');
    const colName = findCol(data[0], '현장명');
    const colBiz = findCol(data[0], '사업구분-2', '사업');

    const cur = data.filter(r => { const d = parseDate(r[colPDate]); return d && inRange(d, range.start, range.end); });
    const prev = data.filter(r => { const d = parseDate(r[colPDate]); return d && inRange(d, range.prevStart, range.prevEnd); });
    const pending = data.filter(r => !parseDate(r[colPDate]) || String(r[colPDate]).trim()==='-');
    const totalSpot = cur.reduce((s,r) => s + (parseInt(r[colSpot])||0), 0);

    renderCards('inspectCards', [
        {label:'실사 완료', value:cur.length+'건', change: cur.length - prev.length},
        {label:'미진행(대기)', value:pending.length+'건'},
        {label:'총 거점 수', value:totalSpot.toLocaleString()+'개'},
        {label:'건당 평균 거점', value: cur.length ? (totalSpot/cur.length).toFixed(1)+'개' : '-'}
    ]);

    document.getElementById('inspectCharts').innerHTML = '';
    const byCompany = topN(countBy(cur, colCompany), 10);
    makeChart('inspectCharts','i-company','bar', byCompany.labels, [{label:'실사 수', data:byCompany.values}], {title:'영업업체별 실사 진행'});

    const byBiz = topN(countBy(cur, colBiz), 8);
    makeChart('inspectCharts','i-biz','doughnut', byBiz.labels, [{data:byBiz.values}], {title:'사업구분별 실사'});

    const months = {};
    data.forEach(r => { const d = parseDate(r[colPDate]); if(d){ const k = d.toISOString().slice(0,7); months[k]=(months[k]||0)+1; }});
    const mk = Object.keys(months).sort().slice(-6);
    makeChart('inspectCharts','i-trend','line', mk, [{label:'월별 실사', data:mk.map(k=>months[k]), fill:true, tension:.3}], {title:'최근 6개월 실사 추이'});

    // 거점수 분포 by company
    const spotByCompany = {};
    cur.forEach(r => { const c = r[colCompany]||'미분류'; spotByCompany[c] = (spotByCompany[c]||0) + (parseInt(r[colSpot])||0); });
    const sc = topN(spotByCompany, 10);
    makeChart('inspectCharts','i-spot','bar', sc.labels, [{label:'거점 수', data:sc.values}], {title:'업체별 거점 수 합계'});

    renderTable('inspectTable', ['현장명','영업업체','사업구분','실사요청일','실사진행일','거점수'],
        cur.map(r => [r[colName],r[colCompany],r[colBiz],String(r[colRDate]).slice(0,10),String(r[colPDate]).slice(0,10),r[colSpot]])
    );
}

function refreshDoc(range) {
    const data = DATA['서류목록'] || [];
    if (!data.length) { renderCards('docCards',[{label:'데이터 없음',value:'-',sub:'서류목록 파일 업로드 필요'}]); document.getElementById('docCharts').innerHTML=''; document.getElementById('docTable').innerHTML=''; return; }
    const colRecvDate = findCol(data[0], '업체접수일자', '접수일자');
    const colContDate = findCol(data[0], '계약/취소일자', '계약일');
    const colStatus = findCol(data[0], '계약여부');
    const colCompany = findCol(data[0], '영업업체명', '영업');
    const colQty = findCol(data[0], '계약수량', '수량');
    const colBiz2 = findCol(data[0], '사업구분-2');
    const colPeriod = findCol(data[0], '약정기간');
    const colElec = findCol(data[0], '전기인입');
    const colName = findCol(data[0], '현장명');

    const cur = data.filter(r => inRange(parseDate(r[colRecvDate]), range.start, range.end));
    const prev = data.filter(r => inRange(parseDate(r[colRecvDate]), range.prevStart, range.prevEnd));
    const contracted = cur.filter(r => String(r[colStatus]).includes('체결'));
    const totalQty = contracted.reduce((s,r) => s + (parseInt(r[colQty])||0), 0);
    const prevContracted = prev.filter(r => String(r[colStatus]).includes('체결'));

    renderCards('docCards', [
        {label:'기간 내 접수', value:cur.length+'건', change: cur.length - prev.length},
        {label:'계약 체결', value:contracted.length+'건', change: contracted.length - prevContracted.length},
        {label:'체결률', value: cur.length ? Math.round(contracted.length/cur.length*100)+'%' : '-'},
        {label:'충전기 수량(체결)', value:totalQty.toLocaleString()+'기'}
    ]);

    document.getElementById('docCharts').innerHTML = '';

    // 업체별
    const byCompany = topN(countBy(contracted, colCompany), 10);
    makeChart('docCharts','d-company','bar', byCompany.labels, [{label:'체결 수', data:byCompany.values}], {title:'영업업체별 계약 체결'});

    // 사업구분
    const byBiz = topN(countBy(contracted, colBiz2), 8);
    makeChart('docCharts','d-biz','doughnut', byBiz.labels, [{data:byBiz.values}], {title:'사업구분별 계약'});

    // 전기인입
    const byElec = topN(countBy(contracted, colElec), 6);
    makeChart('docCharts','d-elec','doughnut', byElec.labels, [{data:byElec.values}], {title:'전기인입 방식별'});

    // 약정기간 분포
    const byPeriod = countBy(contracted, colPeriod);
    const pk = Object.keys(byPeriod).sort((a,b)=>(parseInt(a)||0)-(parseInt(b)||0));
    makeChart('docCharts','d-period','bar', pk.map(k=>k+'년'), [{label:'건수', data:pk.map(k=>byPeriod[k])}], {title:'약정기간별 분포'});

    // 수량 by company
    const qtyByCompany = {};
    contracted.forEach(r => { const c = r[colCompany]||'미분류'; qtyByCompany[c] = (qtyByCompany[c]||0) + (parseInt(r[colQty])||0); });
    const qc = topN(qtyByCompany, 10);
    makeChart('docCharts','d-qty','bar', qc.labels, [{label:'충전기 수량', data:qc.values}], {title:'업체별 계약 충전기 수량'});

    // 월별 추이
    const months = {};
    data.forEach(r => { const d = parseDate(r[colRecvDate]); if(d){ const k = d.toISOString().slice(0,7); if(!months[k]) months[k]={접수:0,체결:0}; months[k].접수++; if(String(r[colStatus]).includes('체결')) months[k].체결++; }});
    const mk = Object.keys(months).sort().slice(-6);
    makeChart('docCharts','d-trend','line', mk, [
        {label:'접수', data:mk.map(k=>months[k]?.접수||0), tension:.3},
        {label:'체결', data:mk.map(k=>months[k]?.체결||0), tension:.3}
    ], {title:'최근 6개월 접수/체결 추이'});

    renderTable('docTable', ['현장명','영업업체','계약여부','사업구분','계약수량','약정기간','전기인입','접수일'],
        cur.slice(0,200).map(r => [
            r[colName], r[colCompany],
            `<span class="badge ${String(r[colStatus]).includes('체결')?'badge-green':'badge-yellow'}">${r[colStatus]}</span>`,
            r[colBiz2], r[colQty], (r[colPeriod]||'')+'년', r[colElec], String(r[colRecvDate]).slice(0,10)
        ])
    );
}

refresh();
</script>
</body>
</html>
